  <gazebo>
    <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
        <topic>cmd_vel</topic>
        <odom_topic>odometry</odom_topic>
        <tf_topic>tf</tf_topic>
        <left_joint>left_mid_joint</left_joint>
        <right_joint>right_mid_joint</right_joint>
        <wheel_separation>0.445</wheel_separation>
        <wheel_radius>0.05675</wheel_radius>
        <max_linear_acceleration>20.0</max_linear_acceleration>
        <min_linear_acceleration>-20.0</min_linear_acceleration>
        <frame_id>odom</frame_id>
        <child_frame_id>base_footprint</child_frame_id>
    </plugin>

    <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
        <topic>cmd_vel</topic>
        <odom_topic>odometry_front</odom_topic> <tf_topic>tf_front</tf_topic>
        <left_joint>left_front_joint</left_joint>
        <right_joint>right_front_joint</right_joint>
        <wheel_separation>0.445</wheel_separation>
        <wheel_radius>0.05675</wheel_radius>
        <max_linear_acceleration>20.0</max_linear_acceleration>
        <min_linear_acceleration>-20.0</min_linear_acceleration>
    </plugin>

    <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
        <topic>cmd_vel</topic>
        <odom_topic>odometry_rear</odom_topic>
        <tf_topic>tf_rear</tf_topic>
        <left_joint>left_rear_joint</left_joint>
        <right_joint>right_rear_joint</right_joint>
        <wheel_separation>0.445</wheel_separation>
        <wheel_radius>0.05675</wheel_radius>
        <max_linear_acceleration>20.0</max_linear_acceleration>
        <min_linear_acceleration>-20.0</min_linear_acceleration>
    </plugin>
</gazebo>
<ros2_control name="GazeboSimSystem" type="system">
    <hardware>
      <plugin>gz_ros2_control/GazeboSimSystem</plugin>
    </hardware>
    
    <joint name="arm_joint_1"> <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    
    <joint name="arm_joint_2">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    
    <joint name="arm_joint_3">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    
    <joint name="arm_joint_4">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    
    <joint name="arm_joint_5">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    
    <joint name="arm_joint_6">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>

  <gazebo>
    <plugin filename="gz_ros2_control-system" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
      <parameters>$(find my_bot_updated)/config/my_controllers.yaml</parameters>
    </plugin>
  </gazebo>
</robot>
