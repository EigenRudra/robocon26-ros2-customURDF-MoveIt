  <gazebo reference="left_track_link">
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
    <kp>1000000.0</kp>
    <kd>100.0</kd>
    <minDepth>0.005</minDepth>
    <material>Gazebo/Black</material>
  </gazebo>

  <gazebo reference="right_track_link">
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
    <kp>1000000.0</kp>
    <kd>100.0</kd>
    <minDepth>0.005</minDepth>
    <material>Gazebo/Black</material>
