    <inertial>
      <origin
        xyz="0.0030129 0.0025118 -0.0093182"
        rpy="0 0 0" />
      <mass
        value="0.19806" />
      <inertia
        ixx="1.776E-05"
        ixy="-1.9198E-06"
        ixz="-7.6806E-21"
        iyy="3.6634E-05"
        iyz="1.4031E-19"
        izz="3.3763E-05" />
    </inertial>
    <visual>
      <origin
