      </geometry>
      <material
        name="">
        <color
          rgba="0.79216 0.81961 0.93333 1" />
      </material>
    </visual>
    <collision name="collision_main_box">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.51 0.025 0.08"/> 
      </geometry>
      <surface>
        <friction>
          <ode>
            <mu>0.1</mu> 
            <mu2>0.1</mu2>
          </ode>
        </friction>
      </surface>
    </collision>

    <collision name="collision_front">
      <origin xyz="0.255 0 0" rpy="1.57079 0 0"/> <geometry>
        <cylinder radius="0.07" length="0.025"/>
      </geometry>
      <surface>
        <friction>
          <ode>
            <mu>1.5</mu> 
            <mu2>1.5</mu2>
